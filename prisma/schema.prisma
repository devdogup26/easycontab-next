// Prisma Schema for DOGUP Fiscal Compliance System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================
enum TipoPessoa {
  PF
  PJ
}

enum GlobalRole {
  ADMIN
  SUPER_ADMIN
}

enum EscopoStatus {
  ATIVO
  VENCIDO
  SUSPENSO
}

enum RegimeTributario {
  SIMPLES_NACIONAL @map("simples_nacional")
  NORMAL @map("normal")
}

enum SituacaoFiscal {
  REGULAR @map("regular")
  REGULARIZADO @map("regularizado")
  IRREGULAR @map("irregular")
}

enum TipoObrigacao {
  DCTFWEB
  EFD_ICMS_IPI
  DEFIS
  DMED
  ECD_SPED
  ECF_SPED
  EFD_CONTRIBUICOES
  ESOCIAL
  PGDAS
  REINF_R2099
  REINF_R4099
}

enum StatusObrigacao {
  ENTREGUE
  NAO_ENTREGUE
  INCONSISTENCIA
  EM_PROCESSAMENTO
  OUTROS
}

enum TipoParcelamento {
  PGFN
  NAO_PREVIDENCIARIO
  SIMPLES_NACIONAL
  SIMPLIFICADO
  PREVIDENCIARIO
}

enum TipoProcuracao {
  COMPLETA
  PARCIAL
  LIMITADA
}

enum StatusProcuracao {
  VALIDA
  VENCIDA
  CANCELADA
  SEM_PROCURACAO
}

// ============================================
// ESCRITORIO - System client (accounting office)
// ============================================
model Escritorio {
  id              Int          @id @default(autoincrement())
  codigo          Int          @unique
  nome            String
  documento       String
  email           String
  telefone        String?
  crc             String?
  status          EscopoStatus @default(ATIVO)
  dataVencimento  DateTime?

  tipoPessoa          TipoPessoa @default(PJ)
  logradouro          String?
  numero              String?
  complemento         String?
  bairro              String?
  cidade              String?
  uf                  String    @default("")
  cep                 String?
  logoUrl             String?
  responsavel         String?

  usuarios            Usuario[]
  clientes            ClienteFinal[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ============================================
// USUÁRIO - Single admin user per escritorio
// Login = email, Password = admin123
// ============================================
model Usuario {
  id        String   @id @default(cuid())
  login     String   @unique
  email     String   @unique
  senha     String
  nome      String
  cargo     String?
  globalRole GlobalRole @default(ADMIN)
  escritorio   Escritorio  @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  escritorioId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([escritorioId])
  @@index([email])
}

// ============================================
// CLIENTE FINAL - CNPJ/CPF Client
// ============================================
model ClienteFinal {
  id                  String            @id @default(cuid())
  tipoPessoa          TipoPessoa
  documento           String            @unique
  nomeRazao           String
  nomeFantasia        String?
  estadoCivil         String?
  inscricaoEstadual   String?
  regime              RegimeTributario @map("regime_tributario")
  escritorio         Escritorio         @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  escritorioId       Int
  situacaoFiscal      SituacaoFiscal @map("situacao_fiscal")
  logradouro          String?
  bairro              String?
  cidade              String?
  uf                  String?
  cep                 String?
  email               String?
  telefone            String?
  responsavelTecnico   String?
  dataAbertura        DateTime?        @map("data_abertura")
  cnae                String?          @map("cnae")
  inscricaoMunicipal  String?          @map("inscricao_municipal")
  optanteSimples      Boolean          @default(false) @map("optante_simples")

  obrigacoes          Obrigacao[]
  parcelamentos       Parcelamento[]
  procuracoes         Procuracao[]

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([escritorioId])
  @@index([documento])
  @@index([situacaoFiscal])
  @@index([regime])
}

// ============================================
// OBRIGAÇÃO ACESSÓRIA
// ============================================
model Obrigacao {
  id              String           @id @default(cuid())
  cliente         ClienteFinal     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId       String
  tipo            TipoObrigacao
  ano             Int
  mes             Int
  dataVencimento  DateTime?
  status          StatusObrigacao
  reciboUrl       String?
  observacao      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([clienteId])
  @@index([tipo, ano, mes])
  @@index([status])
  @@index([dataVencimento])
  @@index([clienteId, status])
}

// ============================================
// PARCELAMENTO
// ============================================
model Parcelamento {
  id          String             @id @default(cuid())
  cliente     ClienteFinal       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId   String
  tipo        TipoParcelamento
  total       Decimal            @db.Decimal(15, 2)
  parcelas    Int
  parcelasEmAtraso Int            @default(0)
  valorAtraso Decimal?            @db.Decimal(15, 2)
  inicio      DateTime
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([clienteId])
  @@index([tipo])
}

// ============================================
// PROCURACAO
// ============================================
model Procuracao {
  id          String           @id @default(cuid())
  cliente     ClienteFinal     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId   String
  tipo        TipoProcuracao
  validade    DateTime
  status      StatusProcuracao
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([clienteId])
  @@index([validade])
}

// ============================================
// NOTIFICACAO
// ============================================
model Notificacao {
  id           String   @id @default(cuid())
  usuarioId    String
  escritorioId Int
  titulo       String
  mensagem     String
  tipo         String
  link         String?
  urgente      Boolean  @default(false)
  lida         Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([usuarioId, lida])
  @@index([escritorioId, createdAt])
}