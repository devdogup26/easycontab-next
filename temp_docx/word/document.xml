<w:document xmlns:wpc="http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas" xmlns:cx="http://schemas.microsoft.com/office/drawing/2014/chartex" xmlns:cx1="http://schemas.microsoft.com/office/drawing/2015/9/8/chartex" xmlns:cx2="http://schemas.microsoft.com/office/drawing/2015/10/21/chartex" xmlns:cx3="http://schemas.microsoft.com/office/drawing/2016/5/9/chartex" xmlns:cx4="http://schemas.microsoft.com/office/drawing/2016/5/10/chartex" xmlns:cx5="http://schemas.microsoft.com/office/drawing/2016/5/11/chartex" xmlns:cx6="http://schemas.microsoft.com/office/drawing/2016/5/12/chartex" xmlns:cx7="http://schemas.microsoft.com/office/drawing/2016/5/13/chartex" xmlns:cx8="http://schemas.microsoft.com/office/drawing/2016/5/14/chartex" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:aink="http://schemas.microsoft.com/office/drawing/2016/ink" xmlns:am3d="http://schemas.microsoft.com/office/drawing/2017/model3d" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:oel="http://schemas.microsoft.com/office/2019/extlst" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:wp14="http://schemas.microsoft.com/office/word/2010/wordprocessingDrawing" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:w14="http://schemas.microsoft.com/office/word/2010/wordml" xmlns:w15="http://schemas.microsoft.com/office/word/2012/wordml" xmlns:w16cex="http://schemas.microsoft.com/office/word/2018/wordml/cex" xmlns:w16cid="http://schemas.microsoft.com/office/word/2016/wordml/cid" xmlns:w16="http://schemas.microsoft.com/office/word/2018/wordml" xmlns:w16du="http://schemas.microsoft.com/office/word/2023/wordml/word16du" xmlns:w16sdtdh="http://schemas.microsoft.com/office/word/2020/wordml/sdtdatahash" xmlns:w16sdtfl="http://schemas.microsoft.com/office/word/2024/wordml/sdtformatlock" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid w16 w16cex w16sdtdh w16sdtfl w16du wp14"><w:body><w:p w14:paraId="3463C8D4" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t># Entrevista - Análise do DOGUP</w:t></w:r></w:p><w:p w14:paraId="731C4B93" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"/><w:p w14:paraId="1F8C36B9" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t>## Contexto do Sistema</w:t></w:r></w:p><w:p w14:paraId="611C1579" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">Sistema </w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:t>multi-tenant</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:t xml:space="preserve"> para escritórios de contabilidade gerenciarem clientes e obrigações fiscais (municipais, estaduais e federais).</w:t></w:r></w:p><w:p w14:paraId="0D709AA0" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"/><w:p w14:paraId="33E8B388" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t>---</w:t></w:r></w:p><w:p w14:paraId="013C4638" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"/><w:p w14:paraId="005E95B5" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t>## Perguntas para Entrevista</w:t></w:r></w:p><w:p w14:paraId="47A1FF8B" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"/><w:p w14:paraId="2CD56514" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t>### Bloco 1: Usuários e Arquitetura</w:t></w:r></w:p><w:p w14:paraId="11937BB9" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"/><w:p w14:paraId="61FE184F" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">1. **Qual o propósito principal do </w:t></w:r><w:proofErr w:type="gramStart"/><w:r><w:t>DOGUP?*</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r><w:t>*</w:t></w:r></w:p><w:p w14:paraId="6BF78010" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">   Sistema de gestão contábil para contadores gerenciarem obrigações fiscais de seus clientes?</w:t></w:r></w:p><w:p w14:paraId="10F8DF33" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:tab/></w:r><w:r w:rsidRPr="008C6E3F"><w:rPr><w:color w:val="EE0000"/></w:rPr><w:t>SIM</w:t></w:r></w:p><w:p w14:paraId="369764E5" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"/><w:p w14:paraId="690675F6" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">2. **Quem são os usuários </w:t></w:r><w:proofErr w:type="gramStart"/><w:r><w:t>finais?*</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r><w:t>*</w:t></w:r></w:p><w:p w14:paraId="37E8573A" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">   - Contador (quem usa o sistema no dia a dia)? </w:t></w:r><w:r w:rsidRPr="008C6E3F"><w:rPr><w:color w:val="EE0000"/></w:rPr><w:t>SIM</w:t></w:r></w:p><w:p w14:paraId="67672562" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">   - Clientes do contador (alguns acessam)? </w:t></w:r><w:r w:rsidRPr="008C6E3F"><w:rPr><w:color w:val="EE0000"/></w:rPr><w:t>NÃO</w:t></w:r></w:p><w:p w14:paraId="7B120E38" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">   - Apenas usuários internos do escritório? </w:t></w:r><w:r w:rsidRPr="008C6E3F"><w:rPr><w:color w:val="EE0000"/></w:rPr><w:t>SIM</w:t></w:r></w:p><w:p w14:paraId="7EB87094" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"/><w:p w14:paraId="04C3CFE3" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">3. **Como está organizada a gestão de clientes </w:t></w:r><w:proofErr w:type="gramStart"/><w:r><w:t>hoje?*</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r><w:t>*</w:t></w:r></w:p><w:p w14:paraId="670ADD27" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">   Como controlam obrigações por cliente, prazos e status?</w:t></w:r></w:p><w:p w14:paraId="26D30905" w14:textId="6ED41A26" w:rsidR="008C6E3F" w:rsidRPr="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:pPr><w:rPr><w:color w:val="EE0000"/></w:rPr></w:pPr><w:r><w:tab/><w:t xml:space="preserve">Os prazos das obrigações que iremos fornecer, será necessário </w:t></w:r><w:proofErr w:type="gramStart"/><w:r><w:t>um apresentação</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r><w:t xml:space="preserve"> em planilha ou outro documento.</w:t></w:r><w:r><w:br/></w:r><w:r><w:rPr><w:color w:val="EE0000"/></w:rPr><w:tab/><w:t>Será necessário confeccionar o documento com as obrigações e prazos, irei providenciar.</w:t></w:r></w:p><w:p w14:paraId="090DD538" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"/><w:p w14:paraId="72B974FF" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t>### Bloco 2: Obrigações Fiscais</w:t></w:r></w:p><w:p w14:paraId="4FCA488E" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"/><w:p w14:paraId="1E4E5B69" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">4. **Quais obrigações municipais, estaduais e federais são mais </w:t></w:r><w:proofErr w:type="gramStart"/><w:r><w:t>frequentes?*</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r><w:t>*</w:t></w:r></w:p><w:p w14:paraId="3C6FE77A" w14:textId="77777777" w:rsidR="00DA5EA8" w:rsidRPr="008C6E3F" w:rsidRDefault="00DA5EA8" w:rsidP="00DA5EA8"><w:pPr><w:rPr><w:color w:val="EE0000"/></w:rPr></w:pPr><w:r w:rsidRPr="008C6E3F"><w:rPr><w:color w:val="EE0000"/></w:rPr><w:lastRenderedPageBreak/><w:t xml:space="preserve">Não há necessidade das obrigações DIRF, RAIS, PER/DCOMP. </w:t></w:r><w:r w:rsidRPr="008C6E3F"><w:rPr><w:color w:val="EE0000"/></w:rPr><w:br/><w:t>Seguem obrigações mais importantes neste primeiro momento: EFD ICMS IPI, DCTFWEB, DEFIS, DMED, ECD SPED, ECF SPED, EFD CONTRIBUIÇÕES, ESOCIAL, PGDAS, REINF (R-2099) REINF(R-4099). Trabalharemos neste primeiro momento somente com as obrigações federais e o estado do DF, contudo a obrigação fiscal inerente ao DF, entra no ambiente federal na EFD ICMS IPI.</w:t></w:r></w:p><w:p w14:paraId="30B3043F" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"/><w:p w14:paraId="5EB6B476" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">5. **E quando precisa transmitir uma </w:t></w:r><w:proofErr w:type="gramStart"/><w:r><w:t>obrigação?*</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r><w:t>*</w:t></w:r></w:p><w:p w14:paraId="2235E8F6" w14:textId="6938504D" w:rsidR="008C6E3F" w:rsidRPr="00DA5EA8" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:pPr><w:rPr><w:color w:val="EE0000"/></w:rPr></w:pPr><w:r><w:t xml:space="preserve">   O processo é manual? Integração com Receita/</w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:t>State</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:t xml:space="preserve"> ou é "cola e copia"?</w:t></w:r><w:r w:rsidR="00DA5EA8"><w:br/></w:r><w:r w:rsidR="00DA5EA8"><w:tab/></w:r><w:r w:rsidR="00DA5EA8" w:rsidRPr="00DA5EA8"><w:rPr><w:color w:val="EE0000"/></w:rPr><w:t>São utilizados outras ferramentas, essa ferramenta não irá fazer a transmissão.</w:t></w:r></w:p><w:p w14:paraId="0936F3E5" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"/><w:p w14:paraId="1C375975" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t>6. **Hoje o escritório consegue ver facilmente:**</w:t></w:r></w:p><w:p w14:paraId="126F9900" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">   - Quais clientes estão com obrigações em atraso?</w:t></w:r></w:p><w:p w14:paraId="5E4D5104" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">   - Quais obrigações vencem nos próximos 7 dias?</w:t></w:r></w:p><w:p w14:paraId="5729F33F" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">   - Qual cliente tem mais pendências?</w:t></w:r></w:p><w:p w14:paraId="7F65AE32" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">   Isto está visível ou precisa "caçar" essa informação?</w:t></w:r></w:p><w:p w14:paraId="7AD8AD18" w14:textId="3F684FA9" w:rsidR="008C6E3F" w:rsidRPr="00DA5EA8" w:rsidRDefault="00DA5EA8" w:rsidP="008C6E3F"><w:pPr><w:rPr><w:color w:val="EE0000"/></w:rPr></w:pPr><w:r><w:tab/></w:r><w:r w:rsidRPr="00DA5EA8"><w:rPr><w:color w:val="EE0000"/></w:rPr><w:t xml:space="preserve">Consegue, mas com </w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="00DA5EA8"><w:rPr><w:color w:val="EE0000"/></w:rPr><w:t>ferramentas  que</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidRPr="00DA5EA8"><w:rPr><w:color w:val="EE0000"/></w:rPr><w:t xml:space="preserve"> precisarão ser contratadas, mas de forma manual fica impossível, dependendo da carteira de clientes.</w:t></w:r></w:p><w:p w14:paraId="65757883" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t>### Bloco 3: Alertas e Prazos</w:t></w:r></w:p><w:p w14:paraId="669D3119" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"/><w:p w14:paraId="3771816C" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">7. **O que acontece quando uma obrigação </w:t></w:r><w:proofErr w:type="gramStart"/><w:r><w:t>vence?*</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r><w:t>*</w:t></w:r></w:p><w:p w14:paraId="187ED0F2" w14:textId="2A66575A" w:rsidR="008C6E3F" w:rsidRPr="00DA5EA8" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:pPr><w:rPr><w:color w:val="EE0000"/></w:rPr></w:pPr><w:r><w:t xml:space="preserve">   Existe algum alerta? O contador descobre que falhou quando já é tarde?</w:t></w:r><w:r w:rsidR="00DA5EA8"><w:br/></w:r><w:r w:rsidR="00DA5EA8"><w:tab/></w:r><w:r w:rsidR="00DA5EA8" w:rsidRPr="00DA5EA8"><w:rPr><w:color w:val="EE0000"/></w:rPr><w:t>Sem uma ferramenta de controle, não há alerta e só tem conhecimento quando recebe a notificação da receita federal. Quem não utiliza uma ferramenta, precisa fazer o controle por planilhas e outras formas possíveis.</w:t></w:r></w:p><w:p w14:paraId="54229D0B" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"/><w:p w14:paraId="4EEF93A0" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t>8. **Dashboards**</w:t></w:r></w:p><w:p w14:paraId="57FF38CA" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">   O que seria mais útil ver?</w:t></w:r></w:p><w:p w14:paraId="75328B26" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">   - Prioridade: quais obrigações vencem em breve?</w:t></w:r></w:p><w:p w14:paraId="2F1134FB" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t xml:space="preserve">   - Problemas: clientes com pendências em aberto?</w:t></w:r></w:p><w:p w14:paraId="422A448B" w14:textId="37555FB6" w:rsidR="008C6E3F" w:rsidRPr="00DA5EA8" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:pPr><w:rPr><w:color w:val="EE0000"/></w:rPr></w:pPr><w:r><w:t xml:space="preserve">   - Volume: total de obrigações por período?</w:t></w:r><w:r w:rsidR="00DA5EA8"><w:br/></w:r><w:r w:rsidR="00DA5EA8"><w:tab/></w:r><w:r w:rsidR="00DA5EA8" w:rsidRPr="00DA5EA8"><w:rPr><w:color w:val="EE0000"/></w:rPr><w:t>Todos.</w:t></w:r></w:p><w:p w14:paraId="6A946DA6" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"/><w:p w14:paraId="5B3F5B62" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"><w:r><w:t>9. **Rotinas repetitivas**</w:t></w:r></w:p><w:p w14:paraId="28A1B5E4" w14:textId="680EB41D" w:rsidR="008C6E3F" w:rsidRPr="00DA5EA8" w:rsidRDefault="008C6E3F" w:rsidP="00DA5EA8"><w:pPr><w:ind w:left="135"/><w:rPr><w:color w:val="EE0000"/></w:rPr></w:pPr><w:r><w:lastRenderedPageBreak/><w:t>Quais tarefas o contador faz todo dia que são repetitivas e poderiam ser automatizadas?</w:t></w:r><w:r w:rsidR="00DA5EA8"><w:br/></w:r><w:r w:rsidR="00DA5EA8" w:rsidRPr="00DA5EA8"><w:rPr><w:color w:val="EE0000"/></w:rPr><w:t>Não entendi a pergunta, alinhamos em reunião</w:t></w:r></w:p><w:p w14:paraId="5ECBA5E5" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidRDefault="008C6E3F" w:rsidP="008C6E3F"/><w:p w14:paraId="45A839A1" w14:textId="77777777" w:rsidR="008C6E3F" w:rsidR